# Required: Your EVM wallet private key (Polygon mainnet)
# Never commit this file to version control
POLYMARKET_PRIVATE_KEY=your_evm_wallet_private_key_here

# Required: Polygon mainnet RPC URL (Chainstack recommended)
CHAINSTACK_NODE=https://polygon-mainnet.core.chainstack.com/your_node_key

# CLOB API credentials — derived automatically on first run
# Run `polymarket wallet status` once, then save the printed credentials here
# to avoid re-deriving on every startup
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=